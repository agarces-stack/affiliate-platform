{
  "name": "affiliate-platform",
  "version": "2.1.0",
  "description": "Plataforma de gestión de equipos de ventas multinivel para agencias de seguros y distribuidores",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:migrate": "node database/migrate.js",
    "change-password": "node scripts/change-password.js",
    "create-admin": "node scripts/create-admin.js",
    "generate-secret": "node scripts/generate-jwt-secret.js",
    "generate-api-key": "node scripts/generate-api-key.js",
    "test": "node --test tests/unit/*.test.js",
    "test:watch": "node --test --watch tests/unit/*.test.js",
    "simulate": "node tests/simulator/run.js",
    "simulate:verbose": "VERBOSE=1 node tests/simulator/run.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "pg": "^8.13.0",
    "ua-parser-js": "^1.0.38",
    "uuid": "^10.0.0"
  }
}
