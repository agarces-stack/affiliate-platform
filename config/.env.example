# Database
DATABASE_URL=postgresql://user:password@localhost:5432/affiliate_platform

# Server
PORT=3000
NODE_ENV=development

# JWT - IMPORTANT: Generate a strong secret for production
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_with_command_above

# Domain
APP_URL=http://localhost:3000
TRACKING_DOMAIN=http://localhost:3000

# CORS (comma-separated origins, leave empty to allow all in dev)
ALLOWED_ORIGINS=http://localhost:3000

# AI Assistant (Claude API for campaign creation + RAG chat)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Embeddings (OpenAI for vector search - RAG)
OPENAI_API_KEY=sk-your-openai-key-here
